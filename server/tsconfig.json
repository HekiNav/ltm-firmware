{
  "compilerOptions": {
    "target": "esnext",
    "rootDir": "src",
    "outDir": "dist",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "moduleDetection": "force",
    "esModuleInterop": true, 
    "forceConsistentCasingInFileNames": true, 
    "strict": true,
    "skipLibCheck": true, 
    "resolveJsonModule": true, 
    "declaration": true, 
    "allowSyntheticDefaultImports": true, 
    "lib": ["ES2022"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}